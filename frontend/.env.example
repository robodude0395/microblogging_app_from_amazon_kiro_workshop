# Frontend Environment Variables
# Copy this file to .env and fill in your actual values after deployment

# API Configuration
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Cognito Authentication
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=your-client-id-here
VITE_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Avatar Configuration
# CloudFront CDN URL for serving user avatar images
VITE_CLOUDFRONT_AVATAR_URL=https://your-cloudfront-id.cloudfront.net

# Default avatar URL served through CloudFront CDN
VITE_DEFAULT_AVATAR_URL=https://your-cloudfront-id.cloudfront.net/default-avatar.png
